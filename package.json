{
  "name": "santiago",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@better-auth/expo": "^1.6.16",
    "@better-auth/prisma-adapter": "^1.6.16",
    "@hookform/resolvers": "^5.4.0",
    "@opentelemetry/api": "^1.9.1",
    "better-auth": "^1.6.16",
    "expo": "~56.0.11",
    "expo-constants": "~56.0.18",
    "expo-font": "~56.0.6",
    "expo-linking": "~56.0.14",
    "expo-network": "^56.0.5",
    "expo-router": "~56.2.10",
    "expo-secure-store": "^56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.6",
    "expo-web-browser": "~56.0.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.78.0",
    "react-native": "0.85.3",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "api:dev": "npm --workspace @santiago/api run dev",
    "api:start": "npm --workspace @santiago/api run start",
    "api:typecheck": "npm --workspace @santiago/api run typecheck",
    "db:generate": "npm --workspace @santiago/database run db:generate",
    "db:migrate": "npm --workspace @santiago/database run db:migrate",
    "db:migrate:dev": "npm --workspace @santiago/database run db:migrate:dev",
    "db:studio": "npm --workspace @santiago/database run db:studio",
    "db:seed": "npm --workspace @santiago/database run db:seed",
    "db:validate": "npm --workspace @santiago/database run db:validate",
    "auth:smoke": "tsx --tsconfig apps/api/tsconfig.json scripts/auth-security-smoke.ts"
  },
  "private": true
}
