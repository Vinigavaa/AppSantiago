# Dev local. Em producao aponte para a API publica do Render:
# EXPO_PUBLIC_AUTH_BASE_URL="https://appsantiago.onrender.com"
EXPO_PUBLIC_AUTH_BASE_URL="http://localhost:3333"

# RevenueCat (assinaturas via loja). Chaves PUBLICAS por plataforma (nao sao
# segredos; ficam no bundle do app). Pegue no painel do RevenueCat > API keys.
# Sem elas a compra fica indisponivel e a tela informa o usuario.
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=""
EXPO_PUBLIC_REVENUECAT_IOS_KEY=""

# Paginas de Termos e Privacidade exibidas na tela de assinatura (exigidas pelas
# lojas). Padrao aponta para o dominio de producao; ajuste se usar outro.
# EXPO_PUBLIC_TERMS_URL="https://appsantiago.onrender.com/termos"
# EXPO_PUBLIC_PRIVACY_URL="https://appsantiago.onrender.com/privacidade"
