# Em producao (Render) estas variaveis ficam no painel Environment, nao neste arquivo.
# Producao: BETTER_AUTH_URL="https://appsantiago.onrender.com"
#           CORS_ORIGIN="https://appsantiago.onrender.com"
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=verify-full"
BETTER_AUTH_SECRET="generate-a-random-secret-with-at-least-32-characters"
BETTER_AUTH_URL="http://localhost:3333"
API_PORT="3333"
CORS_ORIGIN="http://localhost:8081,http://127.0.0.1:8081"

# Deep link scheme do app mobile (Expo).
APP_DEEP_LINK_SCHEME="santiago"

# Landing page web opcional para usuarios que abrem o email sem o app instalado.
# Quando definido, os emails passam a oferecer um fallback para abrir no navegador.
# APP_WEB_URL="https://app.seudominio.com"

# Email. Em desenvolvimento "console" loga no stdout. Em producao use "resend".
EMAIL_PROVIDER="console"
# Endereco com dominio verificado em https://resend.com/domains.
# Producao: EMAIL_FROM="Santiago <noreply@appsantiago.online>"
EMAIL_FROM="Santiago <no-reply@santiago.local>"
# Opcional. Endereco que recebe respostas dos usuarios.
# EMAIL_REPLY_TO="suporte@seudominio.com"
# Chave secreta da Resend.
RESEND_API_KEY=""
