# Em producao (Render) estas variaveis ficam no painel Environment, nao neste arquivo.
# Producao: BETTER_AUTH_URL="https://appsantiago.onrender.com"
#           CORS_ORIGIN="https://appsantiago.onrender.com"
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=verify-full"
BETTER_AUTH_SECRET="generate-a-random-secret-with-at-least-32-characters"
BETTER_AUTH_URL="http://localhost:3333"
API_PORT="3333"
CORS_ORIGIN="http://localhost:8081,http://127.0.0.1:8081"

# Deep link scheme do app mobile (Expo).
APP_DEEP_LINK_SCHEME="santiago"

# Landing page web opcional para usuarios que abrem o email sem o app instalado.
# Quando definido, os emails passam a oferecer um fallback para abrir no navegador.
# APP_WEB_URL="https://app.seudominio.com"

# Email. Em desenvolvimento "console" loga no stdout. Em producao use "resend".
EMAIL_PROVIDER="console"
# Endereco com dominio verificado em https://resend.com/domains.
# Producao: EMAIL_FROM="Santiago <noreply@appsantiago.online>"
EMAIL_FROM="Santiago <no-reply@santiago.local>"
# Opcional. Endereco que recebe respostas dos usuarios.
# EMAIL_REPLY_TO="suporte@seudominio.com"
# Chave secreta da Resend.
RESEND_API_KEY=""

# Cloudinary (armazenamento de imagens). Pegue em:
# https://console.cloudinary.com/app/settings/api-keys
# Em producao ficam no painel Environment do Render (nunca neste arquivo).
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# RevenueCat (assinaturas via loja). Sem estas variaveis os fluxos de compra/webhook
# ficam inertes e a API sobe normalmente. Em producao ficam no Render.
#  - API_KEY: chave secreta (v1) do projeto, usada para confirmar/reconciliar server-side.
#  - WEBHOOK_SECRET: valor que voce define e configura no webhook do RevenueCat; a API
#    so aceita notificacoes cujo header Authorization seja exatamente este valor.
REVENUECAT_API_KEY=""
REVENUECAT_WEBHOOK_SECRET=""
# Identificadores cadastrados nas lojas/RevenueCat (nao sao segredos). Cada plano
# aceita VARIOS ids separados por virgula (Android, iOS, Test Store, ou o REST API
# id prod... do RevenueCat) — todos apontando para o mesmo plano.
#   ex.: REVENUECAT_PRODUCT_MONTHLY="mensal,prodddeba69d4d"
REVENUECAT_ENTITLEMENT_ID="premium"
REVENUECAT_PRODUCT_MONTHLY=""
REVENUECAT_PRODUCT_ANNUAL=""

# Teto mensal de propostas para profissional SEM assinatura (assinante e ilimitado).
PROPOSAL_MONTHLY_LIMIT_FREE="5"
